# .env.example
#
# Copy this file to .env and fill in the values for your local environment.
# Never commit .env — it is listed in .gitignore.

# ── PostgreSQL connection string ─────────────────────────────────────────────
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/academyops_prod

# ── Application settings ─────────────────────────────────────────────────────
# Set to True to enable SQLAlchemy query logging (useful during development).
DEBUG=False
